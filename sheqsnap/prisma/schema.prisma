// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  REPORTER
  SAFETY_OFFICER
  MANAGER
  ADMIN
  VIEWER
  CONTRACTOR
}

enum SeverityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NearMissStatus {
  NEW
  PENDING_APPROVAL
  SUBMITTED
  UNDER_REVIEW
  ACTION_REQUIRED
  IN_PROGRESS
  CLOSED
  CANCELLED
}

enum IncidentStatus {
  NEW
  PENDING_APPROVAL
  SUBMITTED
  UNDER_REVIEW
  ACTION_REQUIRED
  IN_PROGRESS
  CLOSED
  CANCELLED
}

enum ActionStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum LinkedType {
  NEAR_MISS
  INCIDENT
  OTHER
}

enum ApprovalEntityType {
  NEAR_MISS
  INCIDENT
  ACTION
  LOG_ENTRY
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LogType {
  INSPECTION
  TOOLBOX_TALK
  MEETING_MINUTES
  SAFETY_FILE
  PERMIT
  INCIDENT_LOG
  OTHER
}

enum LogEntryStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  ARCHIVED
}

model Department {
  id        String   @id @default(cuid())
  name      String
  site      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  nearMisses NearMiss[]
  incidents  Incident[]
  companies  Company[]
  logEntries LogEntry[]
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members            UserGroup[]
  assignedNearMisses NearMiss[] @relation("NearMissAssignedGroup")
  assignedIncidents  Incident[] @relation("IncidentAssignedGroup")
  assignedActions    Action[]   @relation("ActionAssignedGroup")
  checklistSchedules ChecklistSchedule[] @relation("ScheduleAssignedGroup")
}

model UserGroup {
  userId  String
  groupId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

model Company {
  id               String   @id @default(cuid())
  name             String
  registrationNo   String?
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  siteId           String?
  responsiblePersonId String?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  site              Department? @relation(fields: [siteId], references: [id])
  responsiblePerson User?       @relation("CompanyResponsible", fields: [responsiblePersonId], references: [id])
  contractors       User[]      @relation("UserCompany")
  logEntries        LogEntry[]
}

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  password            String
  role                Role     @default(REPORTER)
  departmentId        String?
  companyId           String?
  responsiblePersonId String?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  department         Department? @relation(fields: [departmentId], references: [id])
  company            Company?    @relation("UserCompany", fields: [companyId], references: [id])
  responsiblePerson  User?       @relation("UserResponsible", fields: [responsiblePersonId], references: [id])
  supervisedUsers    User[]      @relation("UserResponsible")
  managedCompanies   Company[]   @relation("CompanyResponsible")
  groups             UserGroup[]
  reportedNearMisses NearMiss[]  @relation("NearMissReporter")
  assignedNearMisses NearMiss[]  @relation("NearMissAssignedUser")
  reportedIncidents  Incident[]  @relation("IncidentReporter")
  assignedIncidents  Incident[]  @relation("IncidentAssignedUser")
  ownedActions       Action[]    @relation("ActionOwner")
  attachments        Attachment[]
  auditLogs          AuditLog[]
  comments           Comment[]
  requestedApprovals ApprovalRequest[] @relation("ApprovalRequester")
  assignedApprovals  ApprovalRequest[] @relation("ApprovalAssignee")
  uploadedLogEntries  LogEntry[]          @relation("LogEntryUploader")
  approvedLogEntries  LogEntry[]          @relation("LogEntryApprover")
  logAttachments      LogAttachment[]
  onboardingProgress  OnboardingProgress?
  checklistTemplates  ChecklistTemplate[] @relation("ChecklistTemplateCreator")
  schedulesCreated    ChecklistSchedule[] @relation("ScheduleCreator")
  schedulesAssigned   ChecklistSchedule[] @relation("ScheduleAssignedUser")
  checklistAssignments ChecklistAssignment[] @relation("AssignmentUser")
  checklistSubmissions ChecklistSubmission[] @relation("SubmissionUser")
}

model NearMiss {
  id              String         @id @default(cuid())
  referenceNo     String         @unique
  dateReported    DateTime       @default(now())
  reportedById    String
  departmentId    String?
  location        String
  description     String
  riskCategory    String
  severityLevel   SeverityLevel  @default(LOW)
  immediateAction String?
  status          NearMissStatus @default(NEW)
  assignedUserId  String?
  assignedGroupId String?
  targetCloseDate DateTime?
  actualCloseDate DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  reportedBy    User        @relation("NearMissReporter", fields: [reportedById], references: [id])
  department    Department? @relation(fields: [departmentId], references: [id])
  assignedUser  User?       @relation("NearMissAssignedUser", fields: [assignedUserId], references: [id])
  assignedGroup Group?      @relation("NearMissAssignedGroup", fields: [assignedGroupId], references: [id])
  attachments   Attachment[]
  actions       Action[]
  comments      Comment[]
}

model Incident {
  id                 String         @id @default(cuid())
  referenceNo        String         @unique
  dateOfIncident     DateTime
  dateReported       DateTime       @default(now())
  reportedById       String
  departmentId       String?
  location           String
  incidentType       String
  description        String
  personsInvolved    String?
  injuryType         String?
  severityLevel      SeverityLevel  @default(LOW)
  rootCause          String?
  immediateAction    String?
  status             IncidentStatus @default(NEW)
  assignedUserId     String?
  assignedGroupId    String?
  dueDate            DateTime?
  closureDate        DateTime?
  investigationNotes String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  reportedBy    User        @relation("IncidentReporter", fields: [reportedById], references: [id])
  department    Department? @relation(fields: [departmentId], references: [id])
  assignedUser  User?       @relation("IncidentAssignedUser", fields: [assignedUserId], references: [id])
  assignedGroup Group?      @relation("IncidentAssignedGroup", fields: [assignedGroupId], references: [id])
  attachments   Attachment[]
  actions       Action[]
  comments      Comment[]
}

model Action {
  id               String         @id @default(cuid())
  referenceNo      String         @unique
  linkedType       LinkedType     @default(OTHER)
  nearMissId       String?
  incidentId       String?
  description      String
  ownerId          String
  assignedGroupId  String?
  priority         ActionPriority @default(MEDIUM)
  dueDate          DateTime?
  status           ActionStatus   @default(OPEN)
  completionNotes  String?
  dateCompleted    DateTime?
  escalationFlag   Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  owner          User      @relation("ActionOwner", fields: [ownerId], references: [id])
  assignedGroup  Group?    @relation("ActionAssignedGroup", fields: [assignedGroupId], references: [id])
  linkedNearMiss NearMiss? @relation(fields: [nearMissId], references: [id])
  linkedIncident Incident? @relation(fields: [incidentId], references: [id])
  attachments    Attachment[]
  comments       Comment[]
}

model Attachment {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  uploadedById String
  nearMissId   String?
  incidentId   String?
  actionId     String?
  createdAt    DateTime @default(now())

  uploadedBy User      @relation(fields: [uploadedById], references: [id])
  nearMiss   NearMiss? @relation(fields: [nearMissId], references: [id])
  incident   Incident? @relation(fields: [incidentId], references: [id])
  action     Action?   @relation(fields: [actionId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  action      String
  changedById String
  changes     String
  timestamp   DateTime @default(now())

  changedBy  User     @relation(fields: [changedById], references: [id])
}

model Comment {
  id         String   @id @default(cuid())
  body       String
  authorId   String
  nearMissId String?
  incidentId String?
  actionId   String?
  createdAt  DateTime @default(now())

  author   User      @relation(fields: [authorId], references: [id])
  nearMiss NearMiss? @relation(fields: [nearMissId], references: [id])
  incident Incident? @relation(fields: [incidentId], references: [id])
  action   Action?   @relation(fields: [actionId], references: [id])
}

model ApprovalRequest {
  id                 String             @id @default(cuid())
  entityType         ApprovalEntityType
  entityId           String
  requestedById      String
  assignedApproverId String
  status             ApprovalStatus     @default(PENDING)
  rejectionReason    String?
  decidedAt          DateTime?
  createdAt          DateTime           @default(now())

  requestedBy      User @relation("ApprovalRequester", fields: [requestedById], references: [id])
  assignedApprover User @relation("ApprovalAssignee", fields: [assignedApproverId], references: [id])
}

model LogEntry {
  id           String         @id @default(cuid())
  referenceNo  String         @unique
  title        String
  logType      LogType
  companyId    String?
  departmentId String?
  entryDate    DateTime
  description  String
  uploadedById String
  status       LogEntryStatus @default(DRAFT)
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  company      Company?    @relation(fields: [companyId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])
  uploadedBy   User        @relation("LogEntryUploader", fields: [uploadedById], references: [id])
  approvedBy   User?       @relation("LogEntryApprover", fields: [approvedById], references: [id])
  attachments  LogAttachment[]
}

model LogAttachment {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  uploadedById String
  logEntryId   String
  createdAt    DateTime @default(now())

  uploadedBy User     @relation(fields: [uploadedById], references: [id])
  logEntry   LogEntry @relation(fields: [logEntryId], references: [id], onDelete: Cascade)
}

model OnboardingProgress {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id])
  completedSteps String    // JSON array of completed step IDs
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── Checklist System ────────────────────────────────────────────────────────

enum ChecklistItemType {
  CHECKBOX
  YES_NO
  TEXT
  RATING
  PHOTO
}

enum ChecklistRecurrence {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
}

enum ChecklistAssignmentStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  OVERDUE
}

model ChecklistTemplate {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   @default("General")
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User                    @relation("ChecklistTemplateCreator", fields: [createdById], references: [id])
  items       ChecklistTemplateItem[]
  schedules   ChecklistSchedule[]
  assignments ChecklistAssignment[]
}

model ChecklistTemplateItem {
  id          String            @id @default(cuid())
  templateId  String
  order       Int
  label       String
  type        ChecklistItemType @default(CHECKBOX)
  required    Boolean           @default(true)
  description String?
  createdAt   DateTime          @default(now())

  template  ChecklistTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  responses ChecklistItemResponse[]
}

model ChecklistSchedule {
  id                String              @id @default(cuid())
  templateId        String
  assignedToUserId  String?
  assignedToGroupId String?
  startDate         DateTime
  dueTime           String              @default("17:00")
  recurrence        ChecklistRecurrence @default(ONCE)
  weekDay           Int?
  monthDay          Int?
  endDate           DateTime?
  isActive          Boolean             @default(true)
  createdById       String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  template        ChecklistTemplate    @relation(fields: [templateId], references: [id])
  assignedToUser  User?                @relation("ScheduleAssignedUser", fields: [assignedToUserId], references: [id])
  assignedToGroup Group?               @relation("ScheduleAssignedGroup", fields: [assignedToGroupId], references: [id])
  createdBy       User                 @relation("ScheduleCreator", fields: [createdById], references: [id])
  assignments     ChecklistAssignment[]
}

model ChecklistAssignment {
  id                    String                    @id @default(cuid())
  scheduleId            String
  templateId            String
  assignedToUserId      String
  dueDate               DateTime
  status                ChecklistAssignmentStatus @default(PENDING)
  reminderSentDayBefore Boolean                   @default(false)
  reminderSentDayOf     Boolean                   @default(false)
  submittedAt           DateTime?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  schedule       ChecklistSchedule    @relation(fields: [scheduleId], references: [id])
  template       ChecklistTemplate    @relation(fields: [templateId], references: [id])
  assignedToUser User                 @relation("AssignmentUser", fields: [assignedToUserId], references: [id])
  submission     ChecklistSubmission?
}

model ChecklistSubmission {
  id            String   @id @default(cuid())
  assignmentId  String   @unique
  submittedById String
  notes         String?
  submittedAt   DateTime @default(now())

  assignment  ChecklistAssignment    @relation(fields: [assignmentId], references: [id])
  submittedBy User                   @relation("SubmissionUser", fields: [submittedById], references: [id])
  responses   ChecklistItemResponse[]
}

model ChecklistItemResponse {
  id             String   @id @default(cuid())
  submissionId   String
  templateItemId String
  value          String?
  passed         Boolean?
  photoPath      String?
  createdAt      DateTime @default(now())

  submission   ChecklistSubmission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  templateItem ChecklistTemplateItem @relation(fields: [templateItemId], references: [id])
}

// ─── License Manager ─────────────────────────────────────────────────────────

model License {
  id            String    @id @default(cuid())
  holderName    String
  holderType    String    // "employee" | "contractor"
  licenseType   String
  licenseNumber String?
  issuedDate    DateTime?
  expiryDate    DateTime
  status        String    @default("active") // "active" | "expiring_soon" | "expired"
  reminderSent  Boolean   @default(false)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─── Behaviour-Based Safety (BBS) ────────────────────────────────────────────

model BehaviourObservation {
  id                    String   @id @default(cuid())
  observationDate       DateTime
  location              String
  site                  String?
  shaft                 String?
  plant                 String?
  observerName          String
  observerDepartment    String?
  observerId            String?
  teamObserved          String?
  contractorObserved    String?
  employeeObserved      String?
  workType              String   // ROUTINE | NON_ROUTINE | MAINTENANCE
  taskDescription       String
  workContext           String?
  safeBehaviours        String?  // JSON array of strings
  unsafeBehaviours      String?  // JSON array of strings
  hazardsPresent        String?
  potentialConsequences String?
  riskLevel             String?  // LOW | MEDIUM | HIGH
  likelihoodScore       Int?
  impactScore           Int?
  riskScore             Int?
  immediateActionTaken  String?
  workStopped           Boolean  @default(false)
  supervisorNotified    Boolean  @default(false)
  rootCauses            String?  // JSON array of strings
  workerEngaged         Boolean  @default(false)
  workerFeedback        String?
  safetyCategory        String?  // PPE | HOUSEKEEPING | EQUIPMENT | PROCEDURE | ENVIRONMENT | ERGONOMICS | OTHER
  behaviourType         String?
  status                String   @default("OPEN") // OPEN | IN_PROGRESS | CLOSED
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  createdById           String?

  actions               BehaviourAction[]
  evidence              ObservationEvidence[]
}

model BehaviourAction {
  id                String   @id @default(cuid())
  observationId     String
  description       String
  responsiblePerson String
  dueDate           DateTime
  status            String   @default("OPEN") // OPEN | IN_PROGRESS | CLOSED
  closedAt          DateTime?
  closedNote        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  observation       BehaviourObservation @relation(fields: [observationId], references: [id], onDelete: Cascade)
}

model ObservationEvidence {
  id            String   @id @default(cuid())
  observationId String
  fileName      String
  fileUrl       String
  fileType      String?
  uploadedAt    DateTime @default(now())

  observation   BehaviourObservation @relation(fields: [observationId], references: [id], onDelete: Cascade)
}
