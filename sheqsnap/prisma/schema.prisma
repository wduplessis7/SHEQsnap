// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  REPORTER
  SAFETY_OFFICER
  MANAGER
  ADMIN
  VIEWER
  CONTRACTOR
}

enum SeverityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NearMissStatus {
  NEW
  PENDING_APPROVAL
  SUBMITTED
  UNDER_REVIEW
  ACTION_REQUIRED
  IN_PROGRESS
  CLOSED
  CANCELLED
}

enum IncidentStatus {
  NEW
  PENDING_APPROVAL
  SUBMITTED
  UNDER_REVIEW
  ACTION_REQUIRED
  IN_PROGRESS
  CLOSED
  CANCELLED
}

enum ActionStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum LinkedType {
  NEAR_MISS
  INCIDENT
  OTHER
}

enum ApprovalEntityType {
  NEAR_MISS
  INCIDENT
  ACTION
  LOG_ENTRY
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LogType {
  INSPECTION
  TOOLBOX_TALK
  MEETING_MINUTES
  SAFETY_FILE
  PERMIT
  INCIDENT_LOG
  OTHER
}

enum LogEntryStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  ARCHIVED
}

model Department {
  id        String   @id @default(cuid())
  name      String
  site      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  nearMisses        NearMiss[]
  incidents         Incident[]
  actions           Action[]
  companies         Company[]
  logEntries        LogEntry[]
  legalAppointments LegalAppointment[]
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members            UserGroup[]
  assignedNearMisses NearMiss[] @relation("NearMissAssignedGroup")
  assignedIncidents  Incident[] @relation("IncidentAssignedGroup")
  assignedActions    Action[]   @relation("ActionAssignedGroup")
  checklistSchedules ChecklistSchedule[] @relation("ScheduleAssignedGroup")
}

model UserGroup {
  userId  String
  groupId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

model Company {
  id               String   @id @default(cuid())
  name             String
  registrationNo   String?
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  siteId           String?
  responsiblePersonId String?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  site              Department? @relation(fields: [siteId], references: [id])
  responsiblePerson User?       @relation("CompanyResponsible", fields: [responsiblePersonId], references: [id])
  contractors       User[]      @relation("UserCompany")
  logEntries        LogEntry[]
}

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  password            String
  role                Role     @default(REPORTER)
  departmentId        String?
  companyId           String?
  responsiblePersonId String?
  active              Boolean  @default(true)
  mocApprover         Boolean  @default(false)
  isLicensed          Boolean  @default(true)
  reportingOnly       Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  department         Department? @relation(fields: [departmentId], references: [id])
  company            Company?    @relation("UserCompany", fields: [companyId], references: [id])
  responsiblePerson  User?       @relation("UserResponsible", fields: [responsiblePersonId], references: [id])
  supervisedUsers    User[]      @relation("UserResponsible")
  managedCompanies   Company[]   @relation("CompanyResponsible")
  groups             UserGroup[]
  reportedNearMisses NearMiss[]  @relation("NearMissReporter")
  assignedNearMisses NearMiss[]  @relation("NearMissAssignedUser")
  reportedIncidents  Incident[]  @relation("IncidentReporter")
  assignedIncidents  Incident[]  @relation("IncidentAssignedUser")
  ownedActions       Action[]    @relation("ActionOwner")
  attachments        Attachment[]
  auditLogs          AuditLog[]
  comments           Comment[]
  requestedApprovals ApprovalRequest[] @relation("ApprovalRequester")
  assignedApprovals  ApprovalRequest[] @relation("ApprovalAssignee")
  uploadedLogEntries  LogEntry[]          @relation("LogEntryUploader")
  approvedLogEntries  LogEntry[]          @relation("LogEntryApprover")
  logAttachments      LogAttachment[]
  onboardingProgress  OnboardingProgress?
  checklistTemplates  ChecklistTemplate[] @relation("ChecklistTemplateCreator")
  schedulesCreated    ChecklistSchedule[] @relation("ScheduleCreator")
  schedulesAssigned   ChecklistSchedule[] @relation("ScheduleAssignedUser")
  checklistAssignments ChecklistAssignment[] @relation("AssignmentUser")
  checklistSubmissions ChecklistSubmission[] @relation("SubmissionUser")
  mocNotifications    MocNotification[]

  // Legal Appointments
  legalPositionsArchived  LegalPosition[]       @relation("PositionArchivedBy")
  appointmentsCreated     LegalAppointment[]    @relation("AppointmentCreatedBy")
  appointmentsTerminated  LegalAppointment[]    @relation("AppointmentTerminatedBy")
  appointmentDocsUploaded AppointmentDocument[] @relation("AppointmentDocUploader")
  conflictsReviewed       ConflictOfInterest[]  @relation("ConflictReviewer")

  // Chemical Register
  chemicalsAdded      ChemicalItem[]       @relation("ChemicalItemAddedBy")
  sdsUploaded         SdsDocument[]        @relation("SdsUploadedBy")

  // Document management
  ownedDocuments      Document[]           @relation("DocOwner")
  authoredVersions    DocVersion[]         @relation("DocVersionAuthor")
  docStepsAssigned    DocWorkflowStep[]    @relation("DocStepAssignee")
  docStepsCompleted   DocWorkflowStep[]    @relation("DocStepCompleter")
  docComments         DocComment[]         @relation("DocCommentAuthor")
  docAcknowledgements DocAcknowledgement[] @relation("DocAck")
}

model NearMiss {
  id              String         @id @default(cuid())
  referenceNo     String         @unique
  dateReported    DateTime       @default(now())
  reportedById    String
  departmentId    String?
  location        String
  description     String
  riskCategory    String
  severityLevel   SeverityLevel  @default(LOW)
  immediateAction String?
  status          NearMissStatus @default(NEW)
  assignedUserId  String?
  assignedGroupId String?
  targetCloseDate DateTime?
  actualCloseDate DateTime?
  contractorsInvolved Boolean        @default(false)
  contractorDetails   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  reportedBy    User        @relation("NearMissReporter", fields: [reportedById], references: [id])
  department    Department? @relation(fields: [departmentId], references: [id])
  assignedUser  User?       @relation("NearMissAssignedUser", fields: [assignedUserId], references: [id])
  assignedGroup Group?      @relation("NearMissAssignedGroup", fields: [assignedGroupId], references: [id])
  attachments   Attachment[]
  actions       Action[]
  comments      Comment[]
}

model Incident {
  id                 String         @id @default(cuid())
  referenceNo        String         @unique
  dateOfIncident     DateTime
  dateReported       DateTime       @default(now())
  reportedById       String
  departmentId       String?
  location           String
  incidentType       String
  description        String
  personsInvolved    String?
  injuryType         String?
  riskCategory       String?
  severityLevel      SeverityLevel  @default(LOW)
  rootCause          String?
  immediateAction    String?
  status             IncidentStatus @default(NEW)
  assignedUserId     String?
  assignedGroupId    String?
  dueDate            DateTime?
  closureDate        DateTime?
  investigationNotes String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?

  reportedBy    User        @relation("IncidentReporter", fields: [reportedById], references: [id])
  department    Department? @relation(fields: [departmentId], references: [id])
  assignedUser  User?       @relation("IncidentAssignedUser", fields: [assignedUserId], references: [id])
  assignedGroup Group?      @relation("IncidentAssignedGroup", fields: [assignedGroupId], references: [id])
  attachments   Attachment[]
  actions       Action[]
  comments      Comment[]
}

model Action {
  id               String         @id @default(cuid())
  referenceNo      String         @unique
  linkedType       LinkedType     @default(OTHER)
  nearMissId       String?
  incidentId       String?
  description      String
  ownerId          String
  departmentId     String?
  assignedGroupId  String?
  priority         ActionPriority @default(MEDIUM)
  dueDate          DateTime?
  status           ActionStatus   @default(OPEN)
  completionNotes  String?
  dateCompleted    DateTime?
  escalationFlag   Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  owner          User        @relation("ActionOwner", fields: [ownerId], references: [id])
  department     Department? @relation(fields: [departmentId], references: [id])
  assignedGroup  Group?      @relation("ActionAssignedGroup", fields: [assignedGroupId], references: [id])
  linkedNearMiss NearMiss?   @relation(fields: [nearMissId], references: [id])
  linkedIncident Incident?   @relation(fields: [incidentId], references: [id])
  attachments    Attachment[]
  comments       Comment[]
}

model Attachment {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  uploadedById String
  nearMissId   String?
  incidentId   String?
  actionId     String?
  createdAt    DateTime @default(now())

  uploadedBy User      @relation(fields: [uploadedById], references: [id])
  nearMiss   NearMiss? @relation(fields: [nearMissId], references: [id])
  incident   Incident? @relation(fields: [incidentId], references: [id])
  action     Action?   @relation(fields: [actionId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  action      String
  changedById String
  changes     String
  timestamp   DateTime @default(now())

  changedBy  User     @relation(fields: [changedById], references: [id])
}

model Comment {
  id         String   @id @default(cuid())
  body       String
  authorId   String
  nearMissId String?
  incidentId String?
  actionId   String?
  createdAt  DateTime @default(now())

  author   User      @relation(fields: [authorId], references: [id])
  nearMiss NearMiss? @relation(fields: [nearMissId], references: [id])
  incident Incident? @relation(fields: [incidentId], references: [id])
  action   Action?   @relation(fields: [actionId], references: [id])
}

model ApprovalRequest {
  id                 String             @id @default(cuid())
  entityType         ApprovalEntityType
  entityId           String
  requestedById      String
  assignedApproverId String
  status             ApprovalStatus     @default(PENDING)
  rejectionReason    String?
  decidedAt          DateTime?
  createdAt          DateTime           @default(now())

  requestedBy      User @relation("ApprovalRequester", fields: [requestedById], references: [id])
  assignedApprover User @relation("ApprovalAssignee", fields: [assignedApproverId], references: [id])
}

model LogEntry {
  id           String         @id @default(cuid())
  referenceNo  String         @unique
  title        String
  logType      LogType
  companyId    String?
  departmentId String?
  entryDate    DateTime
  description  String
  uploadedById String
  status       LogEntryStatus @default(DRAFT)
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  company      Company?    @relation(fields: [companyId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])
  uploadedBy   User        @relation("LogEntryUploader", fields: [uploadedById], references: [id])
  approvedBy   User?       @relation("LogEntryApprover", fields: [approvedById], references: [id])
  attachments  LogAttachment[]
}

model LogAttachment {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  uploadedById String
  logEntryId   String
  createdAt    DateTime @default(now())

  uploadedBy User     @relation(fields: [uploadedById], references: [id])
  logEntry   LogEntry @relation(fields: [logEntryId], references: [id], onDelete: Cascade)
}

model OnboardingProgress {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id])
  completedSteps String    // JSON array of completed step IDs
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── Checklist System ────────────────────────────────────────────────────────

enum ChecklistItemType {
  CHECKBOX
  YES_NO
  TEXT
  RATING
  PHOTO
}

enum ChecklistRecurrence {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
}

enum ChecklistAssignmentStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  OVERDUE
}

model ChecklistTemplate {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   @default("General")
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy    User                    @relation("ChecklistTemplateCreator", fields: [createdById], references: [id])
  items        ChecklistTemplateItem[]
  schedules    ChecklistSchedule[]
  assignments  ChecklistAssignment[]
  mocResponses MocChecklistResponse[]
}

model ChecklistTemplateItem {
  id          String            @id @default(cuid())
  templateId  String
  order       Int
  label       String
  type        ChecklistItemType @default(CHECKBOX)
  required    Boolean           @default(true)
  description String?
  createdAt   DateTime          @default(now())

  template  ChecklistTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  responses ChecklistItemResponse[]
  mocItems  MocChecklistItem[]
}

model ChecklistSchedule {
  id                String              @id @default(cuid())
  templateId        String
  assignedToUserId  String?
  assignedToGroupId String?
  startDate         DateTime
  dueTime           String              @default("17:00")
  recurrence        ChecklistRecurrence @default(ONCE)
  weekDay           Int?
  monthDay          Int?
  endDate           DateTime?
  isActive          Boolean             @default(true)
  createdById       String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  template        ChecklistTemplate    @relation(fields: [templateId], references: [id])
  assignedToUser  User?                @relation("ScheduleAssignedUser", fields: [assignedToUserId], references: [id])
  assignedToGroup Group?               @relation("ScheduleAssignedGroup", fields: [assignedToGroupId], references: [id])
  createdBy       User                 @relation("ScheduleCreator", fields: [createdById], references: [id])
  assignments     ChecklistAssignment[]
}

model ChecklistAssignment {
  id                    String                    @id @default(cuid())
  scheduleId            String
  templateId            String
  assignedToUserId      String
  dueDate               DateTime
  status                ChecklistAssignmentStatus @default(PENDING)
  reminderSentDayBefore Boolean                   @default(false)
  reminderSentDayOf     Boolean                   @default(false)
  submittedAt           DateTime?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  schedule       ChecklistSchedule    @relation(fields: [scheduleId], references: [id])
  template       ChecklistTemplate    @relation(fields: [templateId], references: [id])
  assignedToUser User                 @relation("AssignmentUser", fields: [assignedToUserId], references: [id])
  submission     ChecklistSubmission?
}

model ChecklistSubmission {
  id            String   @id @default(cuid())
  assignmentId  String   @unique
  submittedById String
  notes         String?
  submittedAt   DateTime @default(now())

  assignment  ChecklistAssignment    @relation(fields: [assignmentId], references: [id])
  submittedBy User                   @relation("SubmissionUser", fields: [submittedById], references: [id])
  responses   ChecklistItemResponse[]
}

model ChecklistItemResponse {
  id             String   @id @default(cuid())
  submissionId   String
  templateItemId String
  value          String?
  passed         Boolean?
  photoPath      String?
  createdAt      DateTime @default(now())

  submission   ChecklistSubmission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  templateItem ChecklistTemplateItem @relation(fields: [templateItemId], references: [id])
}

// ─── License Manager ─────────────────────────────────────────────────────────

model License {
  id            String    @id @default(cuid())
  holderName    String
  holderType    String    // "employee" | "contractor"
  licenseType   String
  licenseNumber String?
  issuedDate    DateTime?
  expiryDate    DateTime
  status        String    @default("active") // "active" | "expiring_soon" | "expired"
  reminderSent  Boolean   @default(false)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─── Behaviour-Based Safety (BBS) ────────────────────────────────────────────

model BehaviourObservation {
  id                    String   @id @default(cuid())
  observationDate       DateTime
  location              String
  site                  String?
  shaft                 String?
  plant                 String?
  observerName          String
  observerDepartment    String?
  observerId            String?
  teamObserved          String?
  contractorObserved    String?
  employeeObserved      String?
  workType              String   // ROUTINE | NON_ROUTINE | MAINTENANCE
  taskDescription       String
  workContext           String?
  safeBehaviours        String?  // JSON array of strings
  unsafeBehaviours      String?  // JSON array of strings
  hazardsPresent        String?
  potentialConsequences String?
  riskLevel             String?  // LOW | MEDIUM | HIGH
  likelihoodScore       Int?
  impactScore           Int?
  riskScore             Int?
  immediateActionTaken  String?
  workStopped           Boolean  @default(false)
  supervisorNotified    Boolean  @default(false)
  rootCauses            String?  // JSON array of strings
  workerEngaged         Boolean  @default(false)
  workerFeedback        String?
  safetyCategory        String?  // PPE | HOUSEKEEPING | EQUIPMENT | PROCEDURE | ENVIRONMENT | ERGONOMICS | OTHER
  behaviourType         String?
  status                String   @default("OPEN") // OPEN | IN_PROGRESS | CLOSED
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  createdById           String?

  actions               BehaviourAction[]
  evidence              ObservationEvidence[]
}

model BehaviourAction {
  id                String   @id @default(cuid())
  observationId     String
  description       String
  responsiblePerson String
  dueDate           DateTime
  status            String   @default("OPEN") // OPEN | IN_PROGRESS | CLOSED
  closedAt          DateTime?
  closedNote        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  observation       BehaviourObservation @relation(fields: [observationId], references: [id], onDelete: Cascade)
}

model ObservationEvidence {
  id            String   @id @default(cuid())
  observationId String
  fileName      String
  fileUrl       String
  fileType      String?
  uploadedAt    DateTime @default(now())

  observation   BehaviourObservation @relation(fields: [observationId], references: [id], onDelete: Cascade)
}

// ─── Inductions / Training ───────────────────────────────────────────────────

model Induction {
  id              String    @id @default(cuid())
  referenceNo     String    @unique
  inducteeName    String
  inducteeType    String    // "employee" | "contractor"
  inducteeId      String?
  inductionType   String    // "Site Safety" | "Fire & Emergency" | "PPE" | "Chemical Handling" | "Equipment" | "Environmental" | "Legal Appointment" | "Other"
  conductedById   String?
  conductedByName String
  conductedDate   DateTime
  expiryDate      DateTime?
  validityMonths  Int?
  status          String    @default("current") // "current" | "expiring_soon" | "expired"
  departmentId    String?
  notes           String?
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── Management of Change (MOC) ──────────────────────────────────────────────

model ChangeRequest {
  id                 String    @id @default(cuid())
  referenceNo        String    @unique
  title              String
  changeType         String    // "Process" | "Equipment / Plant" | "Document / Procedure" | "Personnel" | "Temporary Change" | "Other"
  description        String
  reason             String
  riskAssessment     String?
  affectedAreas      String?
  proposedDate       DateTime?
  implementationDate DateTime?
  reviewDate         DateTime?
  status             String    @default("draft") // "draft" | "pending_approval" | "approved" | "rejected" | "implemented" | "closed"
  requestedById      String?
  requestedByName    String
  approvedById       String?
  approvedByName     String?
  approvedAt         DateTime?
  rejectionReason    String?
  closureNotes            String?
  checklistTemplateId     String?
  checklistCompleted      Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  checklist      MocChecklistResponse?
  notifications  MocNotification[]
}

model MocChecklistResponse {
  id              String    @id @default(cuid())
  changeRequestId String    @unique
  templateId      String
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  changeRequest ChangeRequest          @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)
  template      ChecklistTemplate      @relation(fields: [templateId], references: [id])
  items         MocChecklistItem[]
}

model MocChecklistItem {
  id         String   @id @default(cuid())
  responseId String
  itemId     String
  value      String?
  passed     Boolean?
  createdAt  DateTime @default(now())

  response MocChecklistResponse  @relation(fields: [responseId], references: [id], onDelete: Cascade)
  item     ChecklistTemplateItem @relation(fields: [itemId], references: [id])
}

model MocNotification {
  id                      String    @id @default(cuid())
  changeRequestId         String
  type                    String    // "internal" | "external"
  userId                  String?
  firstName               String
  lastName                String
  company                 String?
  email                   String?
  phone                   String?
  discussedTelephonically Boolean   @default(false)
  notifiedAt              DateTime?
  createdAt               DateTime  @default(now())

  changeRequest ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)
  user          User?         @relation(fields: [userId], references: [id])
}

// ─── Document Management ─────────────────────────────────────────────────────

enum DocType {
  POLICY
  PROCEDURE
  ONE_PAGER
}

enum DocStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum DocWorkflowAction {
  REVIEW
  APPROVE
}

enum DocWorkflowStatus {
  PENDING
  APPROVED
  CHANGES_REQUESTED
}

model Document {
  id             String    @id @default(cuid())
  docNumber      String    @unique
  type           DocType
  title          String
  description    String?
  category       String?
  tags           String?
  ownerId        String
  owner          User      @relation("DocOwner", fields: [ownerId], references: [id])
  currentVersionId String?
  status         DocStatus @default(DRAFT)
  reviewInterval Int?
  nextReviewDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  versions         DocVersion[]
  acknowledgements DocAcknowledgement[]
}

model DocVersion {
  id            String    @id @default(cuid())
  documentId    String
  document      Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionNumber String
  majorVersion  Int
  minorVersion  Int
  isDraft       Boolean   @default(true)
  content       String    @default("{}")
  changeNotes   String?
  authorId      String
  author        User      @relation("DocVersionAuthor", fields: [authorId], references: [id])
  status        DocStatus @default(DRAFT)
  publishedAt   DateTime?
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workflowSteps DocWorkflowStep[]
  comments      DocComment[]
}

model DocWorkflowStep {
  id             String            @id @default(cuid())
  docVersionId   String
  docVersion     DocVersion        @relation(fields: [docVersionId], references: [id], onDelete: Cascade)
  stepOrder      Int
  action         DocWorkflowAction
  assignedRole   String?
  assignedUserId String?
  assignedUser   User?             @relation("DocStepAssignee", fields: [assignedUserId], references: [id])
  status         DocWorkflowStatus @default(PENDING)
  dueDate        DateTime?
  completedAt    DateTime?
  completedById  String?
  completedBy    User?             @relation("DocStepCompleter", fields: [completedById], references: [id])
  note           String?
  createdAt      DateTime          @default(now())
}

model DocComment {
  id           String     @id @default(cuid())
  docVersionId String
  docVersion   DocVersion @relation(fields: [docVersionId], references: [id], onDelete: Cascade)
  authorId     String
  author       User       @relation("DocCommentAuthor", fields: [authorId], references: [id])
  content      String
  isReviewNote Boolean    @default(false)
  resolvedAt   DateTime?
  resolvedById String?
  parentId     String?
  parent       DocComment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies      DocComment[] @relation("CommentThread")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model DocAcknowledgement {
  id             String   @id @default(cuid())
  documentId     String
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionId      String
  userId         String
  user           User     @relation("DocAck", fields: [userId], references: [id])
  acknowledged   Boolean  @default(false)
  acknowledgedAt DateTime?
  dueDate        DateTime?
  createdAt      DateTime @default(now())

  @@unique([documentId, userId])
}

// ─── Legal Appointments ──────────────────────────────────────────────────────

enum OrganizationType {
  PRIVATE_COMPANY
  PUBLIC_COMPANY
  SOE
  MUNICIPALITY
  GOVERNMENT_ENTITY
  NPO
  TRUST
  BOARD
  COMMITTEE
  OTHER
}

enum AppointmentCategory {
  BOARD
  EXECUTIVE
  STATUTORY
  COMMITTEE
  REGULATORY
  OTHER
}

enum AppointmentType {
  PERMANENT
  ACTING
  INTERIM
  TEMPORARY
  FIXED_TERM
  EX_OFFICIO
}

enum AppointmentStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  TERMINATED
  EXPIRED
  RESIGNED
  RENEWED
}

model LegalPosition {
  id                              String              @id @default(cuid())
  name                            String
  code                            String              @unique
  organizationType                OrganizationType
  appointmentCategory             AppointmentCategory
  description                     String?
  isStatutory                     Boolean             @default(false)
  termLengthMonths                Int?
  renewalAllowed                  Boolean             @default(true)
  minQualifications               String?
  eligibilityRules                String?
  requiresResolution              Boolean             @default(false)
  requiresBackgroundCheck         Boolean             @default(false)
  requiresDeclarationOfInterest   Boolean             @default(false)
  requiresGazettePublication      Boolean             @default(false)
  requiredDocuments               String?
  complianceNotes                 String?
  isActive                        Boolean             @default(true)
  archivedAt                      DateTime?
  archivedById                    String?
  archiveReason                   String?
  createdAt                       DateTime            @default(now())
  updatedAt                       DateTime            @updatedAt

  archivedBy   User?              @relation("PositionArchivedBy", fields: [archivedById], references: [id])
  appointments LegalAppointment[]
}

model LegalAppointment {
  id                   String            @id @default(cuid())
  referenceNo          String            @unique
  positionId           String
  entityName           String
  departmentId         String?

  // Appointee details
  fullName             String
  idNumber             String?
  passportNumber       String?
  nationality          String            @default("South African")
  gender               String?
  race                 String?
  disability           String?
  email                String?
  phone                String?
  address              String?
  taxNumber            String?
  employeeNumber       String?

  // Appointment details
  appointmentDate      DateTime
  effectiveDate        DateTime
  endDate              DateTime?
  termLengthMonths     Int?
  appointmentType      AppointmentType   @default(PERMANENT)
  status               AppointmentStatus @default(DRAFT)

  // SA Government-specific fields
  appointmentAuthority String?
  gazettedDate         DateTime?
  gazetteNumber        String?

  // Compliance tracking
  resolutionRef        String?
  acceptanceDate       DateTime?
  consentDate          DateTime?
  complianceNotes      String?

  // Termination
  terminationReason    String?
  terminatedAt         DateTime?
  terminatedById       String?

  // Renewal reminders
  reminder180Sent      Boolean           @default(false)
  reminder90Sent       Boolean           @default(false)
  reminder30Sent       Boolean           @default(false)

  createdById          String
  updatedById          String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  deletedAt            DateTime?

  position     LegalPosition         @relation(fields: [positionId], references: [id])
  department   Department?           @relation(fields: [departmentId], references: [id])
  createdBy    User                  @relation("AppointmentCreatedBy", fields: [createdById], references: [id])
  terminatedBy User?                 @relation("AppointmentTerminatedBy", fields: [terminatedById], references: [id])
  documents    AppointmentDocument[]
  conflicts    ConflictOfInterest[]
}

model AppointmentDocument {
  id             String   @id @default(cuid())
  appointmentId  String
  documentType   String
  fileName       String
  originalName   String
  mimeType       String?
  size           Int?
  version        Int      @default(1)
  expiryDate     DateTime?
  notes          String?
  uploadedById   String
  uploadedAt     DateTime @default(now())

  appointment LegalAppointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  uploadedBy  User            @relation("AppointmentDocUploader", fields: [uploadedById], references: [id])
}

model ConflictOfInterest {
  id               String   @id @default(cuid())
  appointmentId    String
  declarationType  String
  entityName       String?
  description      String
  interestValue    String?
  relationshipType String?
  managementPlan   String?
  status           String   @default("DISCLOSED")
  disclosedAt      DateTime @default(now())
  reviewedById     String?
  reviewedAt       DateTime?
  createdAt        DateTime @default(now())

  appointment LegalAppointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  reviewedBy  User?            @relation("ConflictReviewer", fields: [reviewedById], references: [id])
}

// ─── Platform Licensing ───────────────────────────────────────────────────────

enum ServerTier {
  STARTUP
  GROWTH
  BUSINESS
  CUSTOM
}

model PlatformLicense {
  id                    String     @id @default(cuid())
  clientName            String
  serverTier            ServerTier @default(STARTUP)
  setupFee              Float      @default(0)
  annualLicenseFee      Float      @default(0)
  monthlyHostingFee     Float      @default(650)
  perUserRate           Float      @default(270)
  monthlySupportHours   Float      @default(0)
  supportHourlyRate     Float      @default(385)
  monthlyDevHours       Float      @default(0)
  devHourlyRate         Float      @default(585)
  licenseStart          DateTime   @default(now())
  licenseRenewal        DateTime
  backupEnabled         Boolean    @default(true)
  backupRetentionMonths Int        @default(12)
  maxLicensedUsers      Int?
  active                Boolean    @default(true)
  notes                 String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}

// ─── Chemical Register & SDS Library ────────────────────────────────────────

model ChemicalItem {
  id                String   @id @default(cuid())
  referenceNo       String   @unique
  productName       String
  tradeName         String?
  manufacturer      String?
  supplier          String?
  physicalState     String?
  colour            String?
  odour             String?
  flashPoint        String?
  boilingPoint      String?
  unNumber          String?
  mhiThreshold      Float?
  mhiQuantityOnSite Float?
  isHazardous       Boolean  @default(true)
  emergencyContact  String?
  poisonCentre      String?
  notes             String?
  addedById         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  addedBy      User                    @relation("ChemicalItemAddedBy", fields: [addedById], references: [id])
  components   ChemicalItemComponent[]
  sdsDocuments SdsDocument[]
  locations    ChemicalLocation[]
}

model ChemicalLibrary {
  id                      String   @id @default(cuid())
  name                    String
  casNumber               String?  @unique
  formula                 String?
  ghsPictograms           String   @default("[]")
  hazardClass             String?
  signalWord              String?
  hazardStatements        String   @default("[]")
  precautionaryStatements String   @default("[]")
  pubchemCid              Int?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  usedInItems ChemicalItemComponent[]
}

model ChemicalItemComponent {
  id             String   @id @default(cuid())
  chemicalItemId String
  libraryId      String
  concentration  String?
  notes          String?
  createdAt      DateTime @default(now())

  chemicalItem ChemicalItem    @relation(fields: [chemicalItemId], references: [id])
  library      ChemicalLibrary @relation(fields: [libraryId], references: [id])

  @@unique([chemicalItemId, libraryId])
}

model SdsDocument {
  id             String    @id @default(cuid())
  chemicalItemId String
  version        String    @default("1.0")
  language       String    @default("English")
  effectiveDate  DateTime?
  expiryDate     DateTime?
  filename       String
  originalName   String
  fileSize       Int
  mimeType       String    @default("application/pdf")
  isActive       Boolean   @default(true)
  notes          String?
  uploadedById   String
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  chemicalItem ChemicalItem @relation(fields: [chemicalItemId], references: [id])
  uploadedBy   User         @relation("SdsUploadedBy", fields: [uploadedById], references: [id])
}

model ChemicalLocation {
  id                String   @id @default(cuid())
  chemicalItemId    String
  locationName      String
  buildingArea      String?
  quantity          Float?
  unit              String   @default("kg")
  maxQuantity       Float?
  storageConditions String?
  qrToken           String   @unique @default(cuid())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  chemicalItem ChemicalItem @relation(fields: [chemicalItemId], references: [id])
}
